# N8N
# URL base do n8n (usada nas API routes do Next.js — server side)
N8N_URL=http://185.135.137.113:5678

# URL base do n8n acessivel pelo browser (client components)
NEXT_PUBLIC_N8N_URL=http://185.135.137.113:5678

# Anthropic — necessario para rotas de IA (app/api/ia/)
ANTHROPIC_API_KEY=sua_chave_aqui

# Chave de API do n8n (gerada no editor: Settings > API > Create API Key)
N8N_API_KEY=sua_chave_aqui
